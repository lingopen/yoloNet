<UserControl
    x:Class="yoloNetv2.Controls.LoadingIndicator"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="loadingRoot"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.Styles>
            <Style Selector="Rectangle#Rect1">
                <Style.Animations>
                    <Animation IterationCount="Infinite" Duration="0:0:1">
                        <KeyFrame Cue="0%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                            <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="Rectangle#Rect2">
                <Style.Animations>
                    <Animation
                        Delay="0.1"
                        IterationCount="Infinite"
                        Duration="0:0:1">
                        <KeyFrame Cue="0%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                            <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="Rectangle#Rect3">
                <Style.Animations>
                    <Animation
                        Delay="0.2"
                        IterationCount="Infinite"
                        Duration="0:0:1">
                        <KeyFrame Cue="0%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                            <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="ScaleTransform.ScaleY" Value="0" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Grid.Styles>

        <Border
            Padding="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{Binding #loadingRoot.Background}"
            CornerRadius="5"
            IsHitTestVisible="True"
            ZIndex="1000">
            <StackPanel
                Margin="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Rectangle
                        x:Name="Rect1"
                        Width="6"
                        Height="40"
                        Fill="{Binding #loadingRoot.TextColor}" />
                    <Rectangle
                        x:Name="Rect2"
                        Width="6"
                        Height="40"
                        Fill="{Binding #loadingRoot.TextColor}" />
                    <Rectangle
                        x:Name="Rect3"
                        Width="6"
                        Height="40"
                        Fill="{Binding #loadingRoot.TextColor}" />
                </StackPanel>
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="32"
                    Foreground="{Binding #loadingRoot.TextColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Text="{Binding #loadingRoot.Text, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>